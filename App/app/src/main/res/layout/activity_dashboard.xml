<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/screen_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="AquaControl"
                    android:textColor="@color/white"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textNetworkSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="WiFi sin definir | Broker 192.168.1.127"
                    android:textColor="#CCFFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/textConnectionStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/status_badge"
                android:text="Desconectado"
                android:textColor="@color/white"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/card_surface"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Conexion MQTT"
                android:textColor="@color/ink"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Host/IP Raspberry o broker"
                android:textColor="@color/ink"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/inputRaspberryIp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_surface"
                android:hint="192.168.1.127 o aqua-pi.local"
                android:inputType="textUri"
                android:maxLines="1"
                android:text="@string/default_raspberry_host"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted_ink" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Red WiFi de trabajo"
                android:textColor="@color/ink"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/inputHotspotName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_surface"
                android:hint="SSID donde estaran app, Raspberry y ESP32"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted_ink" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/buttonConnect"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/button_primary"
                    android:text="Conectar"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/buttonDisconnect"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/button_outline"
                    android:text="Desconectar"
                    android:textAllCaps="false"
                    android:textColor="@color/ocean"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/card_surface"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Configuracion inicial ESP32"
                android:textColor="@color/ink"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Primero conecta el celular a AquaControl-Setup. Luego envia el WiFi y el broker que usara la ESP32."
                android:textColor="@color/muted_ink"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Host del portal ESP32"
                android:textColor="@color/ink"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/inputEsp32SetupHost"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_surface"
                android:inputType="textUri"
                android:maxLines="1"
                android:text="@string/default_esp32_setup_host"
                android:textColor="@color/ink" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="WiFi al que se conectara el ESP32"
                android:textColor="@color/ink"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/inputWifiSsid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_surface"
                android:hint="Nombre de tu red WiFi"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted_ink" />

            <EditText
                android:id="@+id/inputWifiPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_surface"
                android:hint="Contrasena WiFi"
                android:inputType="textPassword"
                android:maxLines="1"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted_ink" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Credenciales MQTT"
                android:textColor="@color/ink"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/inputMqttUser"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_surface"
                android:inputType="text"
                android:maxLines="1"
                android:text="@string/default_mqtt_user"
                android:textColor="@color/ink" />

            <EditText
                android:id="@+id/inputMqttPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_surface"
                android:inputType="textPassword"
                android:maxLines="1"
                android:text="@string/default_mqtt_password"
                android:textColor="@color/ink" />

            <Button
                android:id="@+id/buttonProvisionEsp32"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/button_success"
                android:text="Enviar configuracion al ESP32"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <Button
                android:id="@+id/buttonResetEsp32Config"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/button_outline"
                android:text="Borrar WiFi guardado del ESP32"
                android:textAllCaps="false"
                android:textColor="@color/ocean"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textProvisioningStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Esperando configuracion del ESP32"
                android:textColor="@color/muted_ink"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/card_surface"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nivel del tinaco"
                android:textColor="@color/ink"
                android:textSize="20sp"
                android:textStyle="bold" />

            <com.example.aqua_control.ui.TankLevelView
                android:id="@+id/tankLevelView"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:layout_marginTop="10dp" />

            <TextView
                android:id="@+id/textLevel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="--%"
                android:textColor="@color/ink"
                android:textSize="38sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textDistance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Distancia: -- cm"
                android:textColor="@color/muted_ink"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/textEspStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="ESP32: sin datos"
                android:textColor="@color/muted_ink"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/card_surface"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Modo de control"
                android:textColor="@color/ink"
                android:textSize="20sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/radioControlMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/radioAutomatic"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="Automatico: encender al 30% y apagar al llenarse"
                    android:textColor="@color/ink" />

                <RadioButton
                    android:id="@+id/radioManual"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Manual: encender cuando yo quiera, apagar al llenarse"
                    android:textColor="@color/ink" />
            </RadioGroup>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Umbral automatico (%)"
                android:textColor="@color/ink"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/inputAutoThreshold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_surface"
                android:inputType="numberDecimal"
                android:maxLines="1"
                android:text="30"
                android:textColor="@color/ink" />

            <Button
                android:id="@+id/buttonApplyAuto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/button_success"
                android:text="Aplicar modo automatico"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/buttonManualOn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/button_primary"
                    android:text="Motor ON"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/buttonManualOff"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/button_danger"
                    android:text="Motor OFF"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/textModeStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Modo automatico listo. Esperando datos del tinaco."
                android:textColor="@color/muted_ink"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/textLastMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/card_dark"
            android:text="Ultimo MQTT: sin mensajes"
            android:textColor="@color/white"
            android:textSize="14sp" />
    </LinearLayout>
</ScrollView>
